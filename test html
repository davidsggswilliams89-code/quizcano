<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">

<meta name="viewport"
content="width=device-width, initial-scale=1.0">

<title>Quiz Test</title>

<style>

body{

background:#111827;

color:white;

font-family:Arial,sans-serif;

padding:20px;

}

img{

width:300px;

max-width:100%;

border-radius:10px;

margin-top:20px;

}

h2{

color:#F59E0B;

}

</style>

</head>

<body>

<h2>Quiz Test Page</h2>

<p id="status">

Loading...

</p>

<h3 id="quizTitle"></h3>

<p id="questionCount"></p>

<p id="questionNumber"></p>

<img id="questionImage">

<script type="module">
import { initializeApp }
from "https://www.gstatic.com/firebasejs/12.2.1/firebase-app.js";

import {
    getFirestore,
    doc,
    getDoc
}
from "https://www.gstatic.com/firebasejs/12.2.1/firebase-firestore.js";

/* =========================================================
FIREBASE CONFIG
========================================================= */

const firebaseConfig = {

    apiKey: "AIzaSyAnMxqDpdzgKEW1vkRSrLysT-0nu_vEf8Q",

    authDomain: "quizcano.firebaseapp.com",

    projectId: "quizcano",

    storageBucket: "quizcano.firebasestorage.app",

    messagingSenderId: "834135771491",

    appId: "1:834135771491:web:c9998944df72d14a7b2b56"

};

const app =
initializeApp(firebaseConfig);

const db =
getFirestore(app);

/* =========================================================
GET QUIZ ID
========================================================= */

const params =
new URLSearchParams(window.location.search);

const quizId =
params.get("id");
/* =========================================================
LOAD QUIZ
========================================================= */

const status =
document.getElementById("status");

const quizTitle =
document.getElementById("quizTitle");

const questionCount =
document.getElementById("questionCount");

const questionNumber =
document.getElementById("questionNumber");

const questionImage =
document.getElementById("questionImage");

async function loadQuiz(){

    if(!quizId){

        status.textContent =
        "❌ No quiz ID found in URL.";

        return;

    }

    try{

        const snapshot =
        await getDoc(
            doc(db,"quizzes",quizId)
        );

        if(!snapshot.exists()){

            status.textContent =
            "❌ Quiz document not found.";

            return;

        }

        const quiz =
        snapshot.data();

        status.textContent =
        "✅ Quiz Loaded Successfully";

        quizTitle.textContent =
        "Title: " + quiz.quizTitle;

        questionCount.textContent =
        "Questions: " + quiz.questions.length;

        const firstQuestion =
        quiz.questions[0];

        questionNumber.textContent =
        "First Question: " +
        firstQuestion.questionNumber;

        questionImage.src =
        firstQuestion.questionImage;

        console.log(quiz);

    }

    catch(error){

        console.error(error);

        status.textContent =
        "❌ " + error.message;

    }

}

loadQuiz();

</script>

</body>

</html>
